{
  "name": "@webbuf/sig-ed25519-mldsa",
  "version": "3.6.0",
  "description": "Composite Ed25519 + ML-DSA-65 signatures (OpenPGP-style hybrid: classical + post-quantum) for the web, node.js, deno, and bun.",
  "repository": {
    "type": "git",
    "url": "https://github.com/identellica/webbuf"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "test": "vitest --run",
    "test:browser": "vitest --run --browser",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "fix": "pnpm run typecheck && pnpm run lint && pnpm run format",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "engines": {
    "node": ">=20.8.0"
  },
  "packageManager": "pnpm@9.12.3+sha256.24235772cc4ac82a62627cd47f834c72667a2ce87799a846ec4e8e555e2d4b8b",
  "keywords": [
    "ed25519",
    "ml-dsa",
    "mldsa",
    "dilithium",
    "composite",
    "hybrid",
    "post-quantum",
    "pqc",
    "fips204",
    "rfc8032",
    "signature"
  ],
  "author": "Identellica LLC",
  "license": "MIT",
  "peerDependencies": {
    "@webbuf/ed25519": "workspace:^",
    "@webbuf/fixedbuf": "workspace:^",
    "@webbuf/mldsa": "workspace:^",
    "@webbuf/webbuf": "workspace:^"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.13.2",
    "@webbuf/sha256": "workspace:^",
    "buffer": "^6.0.3",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
