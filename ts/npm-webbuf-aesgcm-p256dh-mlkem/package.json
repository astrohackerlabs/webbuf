{
  "name": "@webbuf/aesgcm-p256dh-mlkem",
  "version": "3.8.0",
  "description": "Hybrid AES-256-GCM with P-256 ECDH + ML-KEM-768: classical + post-quantum authenticated encryption for the web, node.js, deno, and bun.",
  "repository": {
    "type": "git",
    "url": "https://github.com/identellica/webbuf"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "test": "vitest --run",
    "test:browser": "vitest --run --browser",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "fix": "pnpm run typecheck && pnpm run lint && pnpm run format",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "engines": {
    "node": ">=20.8.0"
  },
  "packageManager": "pnpm@9.12.3+sha256.24235772cc4ac82a62627cd47f834c72667a2ce87799a846ec4e8e555e2d4b8b",
  "keywords": [
    "aesgcm",
    "p256",
    "ecdh",
    "ml-kem",
    "kyber",
    "hybrid",
    "post-quantum",
    "pqc",
    "fips203",
    "encryption",
    "aead"
  ],
  "author": "Astrohacker",
  "license": "MIT",
  "peerDependencies": {
    "@webbuf/aesgcm": "workspace:^",
    "@webbuf/fixedbuf": "workspace:^",
    "@webbuf/mlkem": "workspace:^",
    "@webbuf/p256": "workspace:^",
    "@webbuf/sha256": "workspace:^",
    "@webbuf/webbuf": "workspace:^"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.13.2",
    "buffer": "^6.0.3",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
