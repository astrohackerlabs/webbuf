{
  "name": "webbuf",
  "version": "3.5.0",
  "description": "Rust/WASM optimized buffers for the web, node.js, deno, and bun.",
  "repository": {
    "type": "git",
    "url": "https://github.com/identellica/webbuf"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "benchmark": "vitest --config vitest.benchmark.config.ts run",
    "test": "vitest --run",
    "test:browser": "vitest --run --browser",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "fix": "pnpm run typecheck && pnpm run lint && pnpm run format",
    "build": "pnpm run build:typescript",
    "build:typescript": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "engines": {
    "node": ">=20.8.0"
  },
  "packageManager": "pnpm@9.12.3+sha256.24235772cc4ac82a62627cd47f834c72667a2ce87799a846ec4e8e555e2d4b8b",
  "keywords": [
    "buffer",
    "base64",
    "hex",
    "uint256",
    "int256",
    "uint128",
    "int128",
    "rust",
    "wasm"
  ],
  "author": "Identellica LLC",
  "license": "MIT",
  "dependencies": {
    "@webbuf/acb3": "workspace:^",
    "@webbuf/acb3dh": "workspace:^",
    "@webbuf/acb3p256dh": "workspace:^",
    "@webbuf/acs2": "workspace:^",
    "@webbuf/acs2dh": "workspace:^",
    "@webbuf/acs2p256dh": "workspace:^",
    "@webbuf/aescbc": "workspace:^",
    "@webbuf/aesgcm": "workspace:^",
    "@webbuf/aesgcm-p256dh": "workspace:^",
    "@webbuf/blake3": "workspace:^",
    "@webbuf/fixedbuf": "workspace:^",
    "@webbuf/mlkem": "workspace:^",
    "@webbuf/mldsa": "workspace:^",
    "@webbuf/numbers": "workspace:^",
    "@webbuf/ripemd160": "workspace:^",
    "@webbuf/rw": "workspace:^",
    "@webbuf/p256": "workspace:^",
    "@webbuf/pbkdf2-sha256": "workspace:^",
    "@webbuf/secp256k1": "workspace:^",
    "@webbuf/sha256": "workspace:^",
    "@webbuf/slhdsa": "workspace:^",
    "@webbuf/webbuf": "workspace:^"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.13.2",
    "buffer": "^6.0.3",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
